# コピーして .env として使う（.env は Git に含めない）
#
# 【A】Messaging API チャネル … Webhook・Reply 用
# 【B】LINEログイン チャネル … LIFF 作成・IDトークン検証用

# 【A】
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# 【B】LIFF タブのアプリ ID（liff-line.html の LIFF_ID と同じ）
# LIFF の Endpoint URL は次のいずれかと完全一致させる（LINE コンソールとズレると Vercel 404 になる）
#   https://www.axer.co.jp/service/liff-line.html  （推奨）
#   https://www.axer.co.jp/service/liff-line
#   https://www.axer.co.jp/liff-line.html
# リポジトリ直下の liff-line.html / liff-line/index.html は上記へクエリ付きで転送（rewrite 非依存）
LINE_LIFF_ID=

# 【B】LINEログイン（LIFF を作ったチャネル）のチャネルID（数値）。LIFF ID の「-」より前と同じことが多い
# 友だち追加の userId と IDトークン sub が一致しないとき:
# LINE Developers → LINEログイン（LIFF のチャネル）→ Basic settings →
# 「Linked LINE Official Account」に、Messaging API を使っている公式アカウントを紐付ける
LINE_LOGIN_CHANNEL_ID=

# 任意
# LINE_LINK_TOKEN_SECRET=
# LINE_FETCH_TIMEOUT_MS=28000
# PUBLIC_BASE_URL=https://example.com

# ---------------------------------------------------------------------------
# 任意 … KV（Redis）— つながなくても「同じLINE内で診断→専用ページ」なら動く。
# つなぐと「別ブラウザで診断した結果」も専用ページ・CSVに出せる。
#
# Vercel での手順（例）:
# 1. Vercel ダッシュボード → 対象プロジェクト → Storage（または Integrations）
# 2. Marketplace から Upstash / Redis などを追加し、同じプロジェクトにリンク
# 3. リンク後、Environment Variables に KV_REST_API_URL と KV_REST_API_TOKEN が入るか確認
# 4. 再デプロイ（Redeploy）
#
# ローカルで試すときだけ、Upstash コンソールの REST URL / Token を手で貼る。
# ---------------------------------------------------------------------------
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
