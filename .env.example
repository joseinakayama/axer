# コピーして .env として使う（.env は Git に含めない）
#
# 【A】Messaging API チャネル … Webhook・Reply 用
# 【B】LINEログイン チャネル … LIFF 作成・IDトークン検証用

# 【A】
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# 【B】LIFF タブのアプリ ID（liff-line.html の LIFF_ID と同じ）
# LIFF の Endpoint URL は次のいずれかと完全一致させる（LINE コンソールとズレると Vercel 404 になる）
#   https://www.axer.co.jp/service/liff-line.html  （推奨）
#   https://www.axer.co.jp/service/liff-line
#   https://www.axer.co.jp/liff-line.html
# リポジトリ直下の liff-line.html / liff-line/index.html は上記へクエリ付きで転送（rewrite 非依存）
LINE_LIFF_ID=

# 【B】LINEログイン（LIFF を作ったチャネル）のチャネルID（数値）。LIFF ID の「-」より前と同じことが多い
# 友だち追加（Messaging API）の userId と IDトークンの sub が一致しないときは、
# LINE Developers で「Messaging API」と「LINEログイン」のチャネル連携・同一プロバイダー設定を確認すること
LINE_LOGIN_CHANNEL_ID=

# 任意
# LINE_LINK_TOKEN_SECRET=
# LINE_FETCH_TIMEOUT_MS=28000
# PUBLIC_BASE_URL=https://example.com
